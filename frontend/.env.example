# Backend API URL
# NOTE: Backend uses mainnet for protocol yield data (ALEX, Velar)
# This provides real market data while vault contract remains on testnet for safe testing
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stacks Network (testnet or mainnet)
# Frontend connects to testnet for vault interactions
NEXT_PUBLIC_NETWORK=testnet

# Stacks API URL
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# BitYield Contract Configuration
# NOTE: Update these addresses after deploying to testnet/mainnet
NEXT_PUBLIC_DEPLOYER_ADDRESS=STKBH2VR2QNEFQDNCVRS7K3DJVQ3WYB38GTENFFQ
NEXT_PUBLIC_VAULT_CONTRACT=yielder
NEXT_PUBLIC_POOL_ORACLE_CONTRACT=pool-oracle
NEXT_PUBLIC_ALEX_POOL_CONTRACT=simulated-alex-pool
NEXT_PUBLIC_VELAR_POOL_CONTRACT=simulated-velar-pool

# Full contract identifiers (for direct contract calls)
NEXT_PUBLIC_VAULT_FULL_CONTRACT=STKBH2VR2QNEFQDNCVRS7K3DJVQ3WYB38GTENFFQ.bityield-vault-v5
NEXT_PUBLIC_POOL_ORACLE_FULL_CONTRACT=STKBH2VR2QNEFQDNCVRS7K3DJVQ3WYB38GTENFFQ.pool-oracle
NEXT_PUBLIC_ALEX_POOL_FULL_CONTRACT=STKBH2VR2QNEFQDNCVRS7K3DJVQ3WYB38GTENFFQ.simulated-alex-pool
NEXT_PUBLIC_VELAR_POOL_FULL_CONTRACT=STKBH2VR2QNEFQDNCVRS7K3DJVQ3WYB38GTENFFQ.simulated-velar-pool

